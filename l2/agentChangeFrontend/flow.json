{
  "flowId": "agentChangeFrontend",
  "schemaVersion": "2026-07-14-v3-contract-shared-layout-fanout",
  "description": "Stage 2 frontend reconciler. The flow scans L4/L5, creates frontend .defs.ts files for L5 todoFrontend=create work, materializes stale L2 runtime files, registers pages, and finalizes L5 owner status. L4 remains read-only. config.json is composed at publish time by nodejsSaveConfigJson.ts.",
  "specFirst": {
    "policy": "This flow.json is the contract. Future structural changes must update this file before code.",
    "modernizationCheckpoint": "2026-07-14 split page creation into deterministic contract/shared, one-layout-per-LLM-call, and deterministic shared reconciliation barriers. The scan reads L4 once and workers reuse the execution cache.",
    "deferred": [
      "Split cfeCreateShared.ts by responsibility.",
      "Unify Studio and CLI materialization repair policy in cfeMaterializeCore."
    ]
  },
  "entry": {
    "agentName": "agentChangeFrontend",
    "file": "l2/agentChangeFrontend/agentChangeFrontend.ts",
    "mode": "deterministic_cli",
    "defaultCommand": "/run",
    "slashCommands": {
      "@@changeFrontend": "Alias for @@changeFrontend /run.",
      "@@changeFrontend /run": "Scan L4/L5 and materialize stale or missing L2 runtime files without resetting done owners.",
      "@@changeFrontend /rebuild all": "Reset done owners to toCreate, regenerate .defs.ts and materialize stale or missing runtime files.",
      "@@changeFrontend /rebuild defs": "Reset done owners to toCreate and regenerate only .defs.ts. Do not materialize runtime files.",
      "@@changeFrontend /help": "Render deterministic help and finish."
    },
    "noInputPolicy": "The agent receives no module, owner, page or device arguments. It discovers actionable work from L5 todoFrontend and existing L2 pipeline files."
  },
  "folderLayout": {
    "currentCodeRoot": "l2/agentChangeFrontend",
    "stepFoldersCreated": [
      "steps/scan",
      "steps/create-contract-shared",
      "steps/create-layout",
      "steps/reconcile-shared",
      "steps/materialize",
      "steps/register",
      "steps/finalize",
      "steps/help"
    ],
    "promptFiles": [
      "steps/create-layout/prompt.md"
    ],
    "helpersFolder": "helpers/ contains shared/policy-frozen modules used across steps and CLIs: cfeCreateShared, cfeL4Contract, cfeMaterializeCore, cfeMaterializeStudio and nodejsMaterializeLlmClient.",
    "currentBoundary": "Step documentation, prompts, and step-owned TypeScript agents live under steps/. Shared helpers live under helpers/. Skills, uxTemplates, CLI entrypoints and the public root agent remain in l2/agentChangeFrontend."
  },
  "reads": [
    "l5/project.json",
    "l5/{module}/process.defs.ts",
    "l4/{module}/module.defs.ts",
    "l4/{module}/ontology/*.defs.ts",
    "l4/{module}/journeys/*.defs.ts",
    "l4/operations/*.defs.ts",
    "l4/workflows/*.defs.ts",
    "l4/rules/{module}Rules.defs.ts",
    "l4/actors/{module}Actors.defs.ts",
    "existing l2/{module}/web/**/*.defs.ts",
    "existing l2/{module}/web/**/*.ts"
  ],
  "writes": [
    "l2/{module}/web/contracts/{page}.defs.ts",
    "l2/{module}/web/shared/{page}.defs.ts",
    "l2/{module}/web/desktop/page11/{page}.defs.ts",
    "l2/{module}/web/contracts/{page}.ts",
    "l2/{module}/web/shared/{page}.ts",
    "l2/{module}/web/desktop/page11/{page}.ts",
    "l2/{module}/web/desktop/page11/{page}.html",
    "l2/{module}/trace/frontend-create-pages/{page}.json",
    "l2/{module}/trace/frontend-create-report.json",
    "l2/{module}/trace/frontend-register-pages/{page}.json",
    "l5/project.json (masters.frontend signature)",
    "status on processed l5 todoFrontend owners"
  ],
  "explicitlyNotWritten": [
    "l4 business artifacts",
    "workspace config.json"
  ],
  "modelAliases": {
    "codehigh": {
      "recommendedFor": [
        "semantic layout generation",
        "materialization code generation"
      ]
    },
    "deterministic": {
      "recommendedFor": [
        "scan",
        "register",
        "finalize",
        "help",
        "phase planning"
      ]
    }
  },
  "engineInvariants": [
    "parallel_dynamic fan-out parents use maxParallel 5 unless this file declares otherwise.",
    "Fan-out progress titles must expose completed, total and failed counters.",
    "Dynamic child args stay compact and unique.",
    "A worker should prefer completed-with-trace plus downstream verification when one item can be repaired without failing the whole pipeline.",
    "PlanIds must be unique; runtime-generated planIds are documented by pattern below."
  ],
  "steps": [
    {
      "planId": "(root)",
      "agentName": "agentChangeFrontend",
      "file": "l2/agentChangeFrontend/agentChangeFrontend.ts",
      "stepFolder": null,
      "executionMode": "sequential",
      "dependsOn": [],
      "modelAlias": "deterministic",
      "goal": "Parse slash command, reset status when requested, and enqueue either help or scan-create-l4.",
      "emits": [
        "help",
        "scan-create-l4"
      ]
    },
    {
      "planId": "help",
      "agentName": "agentCfeHelp",
      "file": "l2/agentChangeFrontend/steps/help/agentCfeHelp.ts",
      "stepFolder": "steps/help",
      "executionMode": "sequential",
      "dependsOn": [
        "(root)"
      ],
      "modelAlias": "deterministic",
      "goal": "Render CLI help and complete."
    },
    {
      "planId": "scan-create-l4",
      "agentName": "agentCfeCreateScanL4",
      "file": "l2/agentChangeFrontend/steps/scan/agentCfeCreateScanL4.ts",
      "stepFolder": "steps/scan",
      "executionMode": "sequential",
      "dependsOn": [
        "(root)"
      ],
      "modelAlias": "deterministic",
      "goal": "Read create context, decide whether page creation and/or materialization are required, and enqueue the next concrete steps.",
      "emits": [
        "create-contract-shared-fanout",
        "create-layout-fanout",
        "reconcile-shared-fanout",
        "materialize-create-l2"
      ],
      "noWorkBehavior": "If no pages are pending and materialize=false, complete with no further steps."
    },
    {
      "planId": "create-contract-shared-fanout",
      "agentName": "agentCfeCreateContractShared",
      "file": "l2/agentChangeFrontend/steps/create-contract-shared/agentCfeCreateContractShared.ts",
      "stepFolder": "steps/create-contract-shared",
      "executionMode": "parallel_dynamic",
      "dependsOn": [
        "scan-create-l4"
      ],
      "maxParallel": 5,
      "progressTitle": "Criar contratos/shared {{completed}}/{{total}}, falhas {{failed}}",
      "dynamicArgs": {
        "shape": {
          "pageId": "string",
          "runId": "string"
        }
      },
      "modelAlias": "deterministic",
      "goal": "For one page, save deterministic contract and base shared defs before any layout generation.",
      "outputs": [
        "l2/{module}/web/contracts/{page}.defs.ts",
        "l2/{module}/web/shared/{page}.defs.ts"
      ]
    },
    {
      "planId": "create-layout-fanout",
      "agentName": "agentCfeCreateLayout",
      "file": "l2/agentChangeFrontend/steps/create-layout/agentCfeCreateLayout.ts",
      "stepFolder": "steps/create-layout",
      "executionMode": "parallel_dynamic",
      "dependsOn": [
        "create-contract-shared-fanout"
      ],
      "maxParallel": 5,
      "progressTitle": "Criar layouts {{completed}}/{{total}}, falhas {{failed}}",
      "dynamicArgs": {
        "shape": {
          "pageId": "string",
          "genome": "string",
          "templateId": "string",
          "runId": "string"
        }
      },
      "modelAlias": "codehigh",
      "strictTool": true,
      "prompt": "steps/create-layout/prompt.md",
      "tool": "cfePageLayoutToolName",
      "goal": "For one pinned page/genome/template tuple, request exactly one semantic page layout and save its defs. The primary page11 is strict; extra variants complete with a warning when invalid.",
      "outputs": [
        "l2/{module}/web/desktop/page{ux}1/{page}.defs.ts"
      ]
    },
    {
      "planId": "reconcile-shared-fanout",
      "agentName": "agentCfeReconcileShared",
      "file": "l2/agentChangeFrontend/steps/reconcile-shared/agentCfeReconcileShared.ts",
      "stepFolder": "steps/reconcile-shared",
      "executionMode": "parallel_dynamic",
      "dependsOn": [
        "create-layout-fanout"
      ],
      "maxParallel": 5,
      "progressTitle": "Reconciliar shared {{completed}}/{{total}}, falhas {{failed}}",
      "dynamicArgs": {
        "shape": {
          "pageId": "string",
          "runId": "string"
        }
      },
      "modelAlias": "deterministic",
      "goal": "After every page variant is saved, merge its layout state references into the single shared defs and mark the page create trace done.",
      "outputs": [
        "l2/{module}/web/shared/{page}.defs.ts",
        "l2/{module}/trace/frontend-create-pages/{page}.json"
      ]
    },
    {
      "planId": "materialize-create-l2",
      "agentName": "agentCfeMaterializeL2",
      "file": "l2/agentChangeFrontend/steps/materialize/agentCfeMaterializeL2.ts",
      "stepFolder": "steps/materialize",
      "executionMode": "sequential",
      "dependsOn": [
        "scan-create-l4",
        "reconcile-shared-fanout when emitted"
      ],
      "modelAlias": "deterministic",
      "goal": "Plan stale or missing materialization work from generated .defs.ts pipelines and enqueue ordered phase barriers.",
      "emitsByConvention": [
        "materialize-phase-contracts",
        "materialize-phase-shared",
        "materialize-phase-pages",
        "register-frontend",
        "finalize-create"
      ]
    },
    {
      "planId": "materialize-phase-{contracts|shared|pages}",
      "agentName": "agentCfeMaterializePhase",
      "file": "l2/agentChangeFrontend/steps/materialize/agentCfeMaterializePhase.ts",
      "stepFolder": "steps/materialize",
      "executionMode": "sequential barrier",
      "dependsOn": [
        "previous phase fanout when applicable"
      ],
      "modelAlias": "deterministic",
      "goal": "Start one phase fan-out and schedule a verify step for that phase.",
      "emitsByConvention": [
        "materialize-phase-{phase}-fanout",
        "materialize-phase-{phase}-verify"
      ]
    },
    {
      "planId": "materialize-phase-{phase}-fanout",
      "agentName": "agentCfeMaterializeGen",
      "file": "l2/agentChangeFrontend/steps/materialize/agentCfeMaterializeGen.ts",
      "stepFolder": "steps/materialize",
      "executionMode": "parallel_dynamic",
      "dependsOn": [
        "materialize-phase-{phase}"
      ],
      "maxParallel": 5,
      "modelAlias": "codehigh",
      "goal": "Generate one materialized runtime file from one pipeline item.",
      "dynamicArgs": {
        "shape": {
          "phase": "contracts|shared|pages",
          "itemId": "string"
        }
      }
    },
    {
      "planId": "materialize-phase-{phase}-verify",
      "agentName": "agentCfeMaterializePhase",
      "file": "l2/agentChangeFrontend/steps/materialize/agentCfeMaterializePhase.ts",
      "stepFolder": "steps/materialize",
      "executionMode": "sequential verify/repair",
      "dependsOn": [
        "materialize-phase-{phase}-fanout"
      ],
      "modelAlias": "deterministic",
      "goal": "Verify generated outputs and run bounded repair rounds when needed.",
      "repairPlanIdConvention": "{itemPlanId}-repair-{attempt}",
      "repairBudget": 2
    },
    {
      "planId": "register-frontend",
      "agentName": "agentCfeRegisterFrontend",
      "file": "l2/agentChangeFrontend/steps/register/agentCfeRegisterFrontend.ts",
      "stepFolder": "steps/register",
      "executionMode": "sequential",
      "dependsOn": [
        "terminal materialization fanouts"
      ],
      "modelAlias": "deterministic",
      "goal": "Write page preview HTML, register generated pages, and sign l5/project.json."
    },
    {
      "planId": "finalize-create",
      "agentName": "agentCfeCreateFinalize",
      "file": "l2/agentChangeFrontend/steps/finalize/agentCfeCreateFinalize.ts",
      "stepFolder": "steps/finalize",
      "executionMode": "sequential",
      "dependsOn": [
        "register-frontend"
      ],
      "modelAlias": "deterministic",
      "goal": "Validate create/register markers and mark processed L5 todoFrontend owners as done."
    }
  ],
  "removedLegacy": [
    {
      "removedAt": "2026-07-14",
      "files": [
        "steps/create-page/agentCfeCreatePage.ts",
        "steps/create-page/cfePromptFiles.ts",
        "steps/create-page/prompt.md"
      ],
      "reason": "The old one-page multi-variant LLM worker was replaced by contract/shared, single-layout, and reconciliation steps so pageVariants is no longer part of the tool contract."
    },
    {
      "removedAt": "2026-07-13",
      "files": [
        "agentCfeV01ScanL4.ts",
        "agentCfeV01PageConsole.ts",
        "agentCfeV01PageChildConsole.ts",
        "agentCfeV01FinalConsole.ts",
        "cfeV01Shared.ts"
      ],
      "reason": "Console-only V01 prototype was not reached by the current flow and conflicted with the create-v1 implementation in future LLM context."
    },
    {
      "removedAt": "2026-07-13",
      "files": [
        "materializeL2.config.json"
      ],
      "reason": "Local materialize config can contain API tokens and must be ignored. The CLI now reads shared LLM settings from mls-base/.env."
    }
  ]
}
