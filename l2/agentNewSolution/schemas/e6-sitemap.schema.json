{
  "$id": "https://collab.codes/agentNewSolution/e6-sitemap/2026-07-19-ns-e6-sitemap-v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "moduleName", "workspaces", "landings", "navigationEdges"],
  "properties": {
    "schemaVersion": { "type": "string", "const": "2026-07-19-ns-e6-sitemap-v1" },
    "moduleName": { "type": "string", "minLength": 1, "pattern": "^[a-z][A-Za-z0-9]*$" },
    "note": { "type": "string" },
    "workspaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["workspaceId", "title", "actors", "kind", "entity", "operationIds", "purpose"],
        "properties": {
          "workspaceId": { "type": "string", "pattern": "^[a-z][A-Za-z0-9]*$", "maxLength": 60 },
          "title": { "type": "string", "minLength": 1 },
          "actors": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "kind": { "type": "string", "enum": ["workflow", "operation", "entityManagement", "landing"] },
          "entity": { "type": "string", "minLength": 1 },
          "workflowId": { "type": "string", "minLength": 1 },
          "operationIds": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "purpose": { "type": "string", "minLength": 5 }
        }
      }
    },
    "landings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["actorId", "workspaceId"],
        "properties": {
          "actorId": { "type": "string", "minLength": 1 },
          "workspaceId": { "type": "string", "minLength": 1 },
          "reason": { "type": "string" }
        }
      }
    },
    "navigationEdges": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["from", "to"],
        "properties": {
          "from": { "type": "string", "minLength": 1 },
          "to": { "type": "string", "minLength": 1 },
          "operationId": { "type": "string", "minLength": 1 },
          "description": { "type": "string" }
        }
      }
    }
  }
}
