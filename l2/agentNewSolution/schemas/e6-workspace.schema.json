{
  "$id": "collab.codes/agentNewSolution/e6-workspace/2026-07-19-ns-e6-workspace-v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["workspaceId", "title", "actors", "kind", "entity", "sections", "purpose"],
  "$defs": {
    "bffField": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "from"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 60 },
        "from": { "type": "string", "minLength": 3 },
        "type": { "enum": ["string", "number", "boolean", "array", "object"] },
        "required": { "type": "boolean" },
        "item": {
          "type": "object",
          "additionalProperties": false,
          "required": ["fields"],
          "properties": {
            "fields": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/bffField" } }
          }
        }
      }
    }
  },
  "properties": {
    "workspaceId": { "type": "string", "pattern": "^[a-z][A-Za-z0-9]*$", "maxLength": 60 },
    "title": { "type": "string", "minLength": 1 },
    "actors": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "kind": { "enum": ["workflow", "operation", "entityManagement", "landing"] },
    "entity": { "type": "string", "minLength": 1 },
    "workflowId": { "type": "string", "minLength": 1 },
    "purpose": { "type": "string", "minLength": 5 },
    "bffCalls": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["bffId", "kind", "uses"],
        "properties": {
          "bffId": { "type": "string", "pattern": "^[a-z][A-Za-z0-9]*$", "maxLength": 60 },
          "kind": { "enum": ["query", "command"] },
          "route": { "type": "string", "minLength": 1 },
          "uses": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["operationId"],
              "properties": {
                "operationId": { "type": "string", "minLength": 1 },
                "optional": { "type": "boolean" }
              }
            }
          },
          "input": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["name"],
              "properties": {
                "name": { "type": "string", "minLength": 1, "maxLength": 60 },
                "from": { "type": "string", "minLength": 3 },
                "type": { "enum": ["string", "number", "boolean", "array", "object"] },
                "required": { "type": "boolean" }
              }
            }
          },
          "output": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "fields"],
            "properties": {
              "kind": { "enum": ["object", "list", "paginated"] },
              "fields": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/bffField" } }
            }
          }
        }
      }
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sectionId", "intent", "organisms"],
        "properties": {
          "sectionId": { "type": "string", "pattern": "^[a-z][A-Za-z0-9]*$", "maxLength": 60 },
          "intent": { "type": "string", "minLength": 3 },
          "organisms": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["role"],
              "properties": {
                "operationId": { "type": "string", "minLength": 1 },
                "role": { "enum": ["primarySurface", "filterControl", "contextualAction", "detailPanel", "batchAction", "navigationEntry", "hero", "banner", "richText", "imageSet", "ctaLink", "showcase"] },
                "dataSource": { "type": "string", "minLength": 1 },
                "action": { "type": "string", "minLength": 1 },
                "attachTo": { "type": "string", "minLength": 1 },
                "slice": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      }
    },
    "operationIds": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "sliceHash": { "type": "string" }
  }
}
