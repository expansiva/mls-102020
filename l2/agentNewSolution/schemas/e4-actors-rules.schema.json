{
  "$id": "https://collab.codes/agentNewSolution/e4-actors-rules/2026-07-07-ns-e4-v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "moduleName", "userLanguage", "actors", "rules", "externalRefs"],
  "properties": {
    "schemaVersion": { "type": "string", "const": "2026-07-07-ns-e4-v1" },
    "moduleName": { "type": "string", "minLength": 1, "pattern": "^[a-z][A-Za-z0-9]*$" },
    "userLanguage": { "type": "string", "minLength": 2 },
    "createdAt": { "type": "string" },
    "actors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["actorId", "title", "description"],
        "properties": {
          "actorId": { "type": "string", "pattern": "^[a-z][A-Za-z0-9]*$", "maxLength": 60 },
          "title": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "roleScope": { "type": "string", "pattern": "^[a-z][A-Za-z0-9]*:[a-z][A-Za-z0-9]*$" }
        }
      }
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ruleId", "title", "description", "appliesTo", "layer", "sourceJourneyRules"],
        "properties": {
          "ruleId": { "type": "string", "pattern": "^[a-z][A-Za-z0-9]*$", "maxLength": 80 },
          "title": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 20 },
          "appliesTo": { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^[A-Z][A-Za-z0-9]*$" } },
          "layer": { "type": "string", "enum": ["domain", "application"] },
          "sourceJourneyRules": { "type": "array", "items": { "type": "string", "minLength": 1 } }
        }
      }
    },
    "externalRefs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mdm", "horizontals", "plugins", "agents"],
      "properties": {
        "mdm": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["title", "reason"],
            "properties": {
              "title": { "type": "string", "minLength": 1 },
              "reason": { "type": "string", "minLength": 1 }
            }
          }
        },
        "horizontals": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["title", "reason"],
            "properties": {
              "title": { "type": "string", "minLength": 1 },
              "reason": { "type": "string", "minLength": 1 }
            }
          }
        },
        "plugins": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["title", "reason"],
            "properties": {
              "title": { "type": "string", "minLength": 1 },
              "reason": { "type": "string", "minLength": 1 }
            }
          }
        },
        "agents": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["title", "reason"],
            "properties": {
              "title": { "type": "string", "minLength": 1 },
              "reason": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    }
  }
}
