{
  "$id": "https://collab.codes/schemas/agentNewSolution/e1-draft/2026-07-05-v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "agentNewSolution E1 Draft",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "moduleName",
    "moduleTitle",
    "userLanguage",
    "sourcePrompt",
    "problem",
    "actors",
    "scope",
    "openQuestions",
    "assumptions",
    "createdAt"
  ],
  "properties": {
    "schemaVersion": { "type": "string", "const": "2026-07-05-ns-e1-v1" },
    "moduleName": { "type": "string", "minLength": 1, "maxLength": 60, "pattern": "^[a-z][a-zA-Z0-9]*$" },
    "moduleTitle": { "type": "string", "minLength": 1, "maxLength": 120 },
    "userLanguage": { "type": "string", "minLength": 2, "maxLength": 20 },
    "sourcePrompt": { "type": "string", "minLength": 5 },
    "problem": { "type": "string", "minLength": 10 },
    "actors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["actorId", "name", "assumption"],
        "properties": {
          "actorId": { "type": "string", "minLength": 1, "pattern": "^[a-z][a-zA-Z0-9]*$" },
          "name": { "type": "string", "minLength": 1 },
          "assumption": { "type": "string", "minLength": 1 }
        }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["in", "out"],
      "properties": {
        "in": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "out": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    },
    "openQuestions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["questionId", "question", "classification", "impact"],
        "properties": {
          "questionId": { "type": "string", "minLength": 1, "pattern": "^[a-z][a-zA-Z0-9]*$" },
          "question": { "type": "string", "minLength": 1 },
          "classification": { "type": "string", "enum": ["blocking", "assumed"] },
          "defaultAnswer": { "type": "string" },
          "impact": { "type": "string", "minLength": 1 }
        }
      }
    },
    "assumptions": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "createdAt": { "type": "string", "minLength": 10 }
  }
}
