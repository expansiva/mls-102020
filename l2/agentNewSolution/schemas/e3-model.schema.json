{
  "$id": "collab.codes/agentNewSolution/e3-model/2026-07-07-ns-e3-v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "moduleName", "userLanguage", "module", "entities", "relationships"],
  "properties": {
    "schemaVersion": { "const": "2026-07-07-ns-e3-v1" },
    "moduleName": { "type": "string", "minLength": 1, "pattern": "^[a-z][A-Za-z0-9]*$" },
    "userLanguage": { "type": "string", "minLength": 2 },
    "version": { "type": "integer" },
    "createdAt": { "type": "string" },
    "module": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "purpose", "businessDomain", "languages", "visualStyle"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "purpose": { "type": "string", "minLength": 10 },
        "businessDomain": { "type": "string", "minLength": 3 },
        "languages": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 2 } },
        "visualStyle": { "type": "string", "minLength": 3 }
      }
    },
    "entities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["entityId", "title", "description", "kind", "ownership"],
        "properties": {
          "entityId": { "type": "string", "pattern": "^[A-Z][A-Za-z0-9]*$", "maxLength": 60 },
          "title": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 10 },
          "kind": { "enum": ["core", "supporting", "event", "metric", "mdm"] },
          "ownership": { "enum": ["moduleOwned", "mdmOwned", "horizontalOwned", "pluginOwned", "existingModuleOwned", "external"] },
          "statusEnum": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "lifecycleStates": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "sourceRefs": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "journeyIds": { "type": "array", "items": { "type": "string" } },
              "featureIds": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    },
    "relationships": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["relationshipId", "fromEntity", "toEntity", "type", "description"],
        "properties": {
          "relationshipId": { "type": "string", "pattern": "^[a-z][A-Za-z0-9]*$" },
          "fromEntity": { "type": "string" },
          "toEntity": { "type": "string" },
          "type": { "enum": ["oneToOne", "oneToMany", "manyToOne", "manyToMany", "partOf"] },
          "description": { "type": "string", "minLength": 5 }
        }
      }
    }
  }
}
