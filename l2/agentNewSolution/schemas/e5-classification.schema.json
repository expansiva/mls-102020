        "required": ["workflowId", "title", "actorId", "primaryEntity", "featureRefs", "operationIds"],
        "properties": {
          "workflowId": { "type": "string", "pattern": "^[a-z][A-Za-z0-9]*$", "maxLength": 60 },
          "title": { "type": "string", "minLength": 1 },
          "actorId": { "type": "string", "minLength": 1 },
          "primaryEntity": { "type": "string", "minLength": 1 },
          "featureRefs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "operationIds": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
        }
      }
    },
    "operations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["operationId", "title", "actorId", "entity", "kind", "featureRefs"],
        "properties": {
          "operationId": { "type": "string", "pattern": "^[a-z][A-Za-z0-9]*$", "maxLength": 60 },
          "title": { "type": "string", "minLength": 1 },
          "actorId": { "type": "string", "minLength": 1 },
          "entity": { "type": "string", "minLength": 1 },
          "kind": { "type": "string", "enum": ["create", "update", "delete", "query", "view"] },
          "featureRefs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "workflowId": { "type": "string", "minLength": 1 }
